# SERVIDOR 1: Servidor principal con todas las features
server {
    listen 8080;
    host 127.0.0.1;
    server_name main_server;
    
    root ./www/main;
    index index.html;
    
    # Tamaño máximo de body (ej. 2MB)
    client_max_body_size 2097152;
    
    # Páginas de error por defecto
    error_page 404 /404.html;
    error_page 405 /405.html;
    error_page 413 /413.html;

    # 1. Ruta estándar (Static website)
    location / {
        methods GET;
        autoindex off;
    }

    # 2. Ruta para probar Directory Listing (Autoindex)
    location /assets {
        methods GET;
        autoindex on;
    }

    # 3. Ruta para probar subida de archivos (Uploads)
    location /upload {
        methods GET POST DELETE;
        upload_store ./www/main/uploads;
    }

    # 4. Ruta para probar Redirección HTTP
    location /google {
        return 302 https://www.google.com;
    }

    location /old-page {
        return 301 /new-page.html;
    }

    # 5. Ruta para probar CGI
    location /cgi-bin {
        methods GET POST;
        # Asumiendo que has instalado php-cgi o python3
        cgi_info .php /usr/bin/php-cgi;
        cgi_info .py /usr/bin/python3;
    }
}

# SERVIDOR 2: Servidor en distinto puerto para entregar "diferente contenido"
server {
    listen 8081;
    host 127.0.0.1;
    server_name secondary_server;
    
    root ./www/alt;
    index index.html;
    
    location / {
        methods GET;
    }
}
