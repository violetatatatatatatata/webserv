server {
    listen 8080;
    host 127.0.0.1;
    server_name localhost mi_servidor_virtual;
    client_max_body_size 2097152;
    root ./www/html;
    index index.html;
    error_page 404 /errores/404.html;
    error_page 500 /errores/500.html;

    location / {
        methods GET;
        root ./www/html;
        index default.html;
        autoindex off;
    }

    location /uploads {
        methods GET POST DELETE;
        root ./www/uploads;
        upload_store ./www/uploads/files;
        autoindex on;
    }

    location /cgi-bin {
        methods GET POST;
        root ./www/cgi-bin;
        cgi_info .php /usr/bin/php-cgi;
        cgi_info .py /usr/bin/python3;
    }
}
